{
  "name": "LaTeXClaude",
  "build": {
    "dockerfile": "../Dockerfile"
  },
  "workspaceMount": "source=${localWorkspaceFolder},target=/workspace,type=bind",
  "workspaceFolder": "/workspace",
  "remoteUser": "vscode",
  "postCreateCommand": "bash /workspace/scripts/setup.sh",
  "customizations": {
    "vscode": {
      "extensions": [
        "James-Yu.latex-workshop",
        "anthropic.claude-code",
        "valentjn.vscode-ltex",
        "streetsidesoftware.code-spell-checker",
        "mhutchie.git-graph",
        "eamodio.gitlens"
      ],
      "settings": {
        "terminal.integrated.defaultProfile.linux": "bash",
        "latex-workshop.latex.autoBuild.run": "onFileChange",
        "latex-workshop.view.pdf.viewer": "tab",
        "latex-workshop.latex.tools": [
          {
            "name": "latexmk",
            "command": "latexmk",
            "args": ["%DOC%"]
          }
        ],
        "latex-workshop.latex.recipes": [
          {
            "name": "latexmk",
            "tools": ["latexmk"]
          }
        ],
        "ltex.language": "auto",
        "ltex.dictionary": {
          "en-US": [
            "ipsj", "IPSJ", "ieice", "IEICE",
            "latexmk", "latexmkrc", "latexdiff",
            "platex", "uplatex", "lualatex", "pdflatex",
            "dvipdfmx", "synctex", "nonstopmode",
            "biber", "bibtex", "upbibtex", "biblatex", "biblio",
            "jsarticle", "documentclass"
          ],
          "ja-JP": [
            "ipsj", "IPSJ", "ieice", "IEICE",
            "latexmk", "latexmkrc", "latexdiff",
            "platex", "uplatex", "lualatex", "pdflatex",
            "dvipdfmx", "synctex", "nonstopmode",
            "biber", "bibtex", "upbibtex", "biblatex", "biblio",
            "jsarticle", "documentclass"
          ]
        }
      }
    }
  }
}
