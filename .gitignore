# LaTeX 中間ファイル
*.aux
*.bbl
*.bcf
*.blg
*.fdb_latexmk
*.fls
*.idx
*.ind
*.lof
*.lot
*.nav
*.out
*.run.xml
*.snm
*.synctex.gz
*.toc
*.dvi

# ビルド成果物（必要に応じてコメントアウト）
*.pdf

# latexdiff 一時ファイル
diff_*.pdf
diff_*.tex

# 旧設計の中間ファイル（生成されても追跡しない）
_header.tex
_footer.tex
format_config.tex
format_biblio.tex

# Python
__pycache__/
*.py[cod]
.venv/
venv/
.env

# Node.js
node_modules/

# バックアップ（中身は管理するが空ディレクトリを保持）
backups/*
!backups/.gitkeep

# figures（研究用画像は追跡しない）
figures/*
!figures/.gitkeep

# images（研究用画像）
images/

# papers（論文本体は追跡しない。ディレクトリ構造のみ保持）
papers/*
!papers/.gitkeep

# format/（ベンダー提供 cls/sty は追跡しない）
format/ipsj*/
format/ieee*/
format/acm*/

# ルート直下の論文ファイル（旧設計の残骸）
/main.tex
/references.bib
/main.*.log
/main.bcf-SAVE-ERROR
/main.log

# OS
.DS_Store
Thumbs.db
